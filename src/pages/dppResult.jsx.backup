import { useMemo } from "react";
import { useLocation, useNavigate, useParams } from "react-router-dom";

const dppResult = () => {
  const { id } = useParams();
  const navigate = useNavigate();
  const { state } = useLocation();

  // We expect the DPP data to be passed from the dashboard via route state
  const dpp = useMemo(() => {
    if (!state || !state.dpp) return null;
    // Make sure id from URL matches the passed DPP (as string)
    return String(state.dpp.id) === String(id) ? state.dpp : null;
  }, [state, id]);

  if (!dpp || !dpp.attempted) {
    return (
      <main className="page flex min-h-screen items-center justify-center bg-[#050816] text-white">
        <div className="panel rounded-2xl bg-[#0b1220] border border-[#1f2937] px-8 py-6 text-center">
          <p className="muted text-sm text-gray-300 mb-4">
            No DPP attempt found for this topic.
          </p>
          <button
            className="pill-button px-5 py-2 rounded-full bg-[#2563eb] hover:bg-[#1d4ed8] text-sm font-medium transition"
            onClick={() => navigate(-1)}
          >
            Go Back
          </button>
        </div>
      </main>
    );
  }

  const total = (dpp.correct || 0) + (dpp.incorrect || 0);

  return (
    <main className="page overview-page min-h-screen bg-[#050816] text-white px-8 py-8">
      <h1 className="text-2xl font-semibold mb-6">
        {dpp.topicName} — DPP Result
      </h1>

      <div className="stats-grid grid grid-cols-1 md:grid-cols-4 gap-4">
        <div className="panel stat-card rounded-2xl bg-[#0b1220] border border-[#1f2937] p-5">
          <p className="muted text-xs text-gray-400 mb-2">Correct Questions</p>
          <div className="stat-value text-2xl font-semibold text-emerald-400">
            {dpp.correct}
          </div>
        </div>

        <div className="panel stat-card rounded-2xl bg-[#0b1220] border border-[#1f2937] p-5">
          <p className="muted text-xs text-gray-400 mb-2">Incorrect Questions</p>
          <div className="stat-value text-2xl font-semibold text-red-400">
            {dpp.incorrect}
          </div>
        </div>

        <div className="panel stat-card rounded-2xl bg-[#0b1220] border border-[#1f2937] p-5">
          <p className="muted text-xs text-gray-400 mb-2">Accuracy</p>
          <div className="stat-value text-2xl font-semibold">
            {dpp.accuracy}
            <span className="stat-total text-sm text-gray-300 ml-1">%</span>
          </div>
        </div>

        <div className="panel stat-card rounded-2xl bg-[#0b1220] border border-[#1f2937] p-5">
          <p className="muted text-xs text-gray-400 mb-2">Total Attempted</p>
          <div className="stat-value text-2xl font-semibold">{total}</div>
        </div>
      </div>

      <div className="mt-8">
        <button
          onClick={() => navigate(-1)}
          className="px-5 py-2 rounded-full bg-[#111827] hover:bg-[#1a1f2e] border border-[#1f2937] text-sm transition"
        >
          Back to Dashboard
        </button>
      </div>
    </main>
  );
};

export default dppResult;


